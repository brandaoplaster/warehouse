<section class="w-full">
  <section class="relative w-full mb-10">
    <%= render "carousel" %>

    <div class="absolute inset-0 bg-black/40 flex items-center pointer-events-none">
      <div class="container mx-auto px-5 text-white">
        <h1 class="text-3xl md:text-5xl font-bold mb-4">
          Featured Products
        </h1>

        <p class="max-w-lg">
          Discover our top items
        </p>
      </div>
    </div>
  </section>

  <section class="space-y-4 pb-6">
    <h2 class="text-xl font-semibold">Produtos</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <%= render partial: "product_list", collection: @products, as: :product %>
    </div>
  </section>
</section>
