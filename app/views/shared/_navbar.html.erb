<nav class="bg-white fixed w-full z-20 top-0 start-0 border-b border-default">
  <div class="max-w-screen-xl flex flex-wrap items-center justify-between mx-auto p-4">

    <!-- logo -->
    <a href="/" class="flex items-center space-x-3">
      <img src="https://flowbite.com/docs/images/logo.svg" class="h-7" alt="Warehouse Logo" />
      <span class="self-center text-xl font-semibold whitespace-nowrap">
        Warehouse
      </span>
    </a>

    <!-- right (search + actions) -->
    <div class="flex items-center gap-4 md:order-2">

      <!-- search (desktop) -->
      <div class="relative hidden md:block">
        <div class="absolute inset-y-0 start-0 flex items-center ps-3 pointer-events-none">
          <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-width="2" d="m21 21-3.5-3.5M17 10a7 7 0 1 1-14 0 7 7 0 0 1 14 0Z"/>
          </svg>
        </div>
        <input
          type="text"
          class="block w-full ps-9 pe-3 py-2 text-sm border rounded-md"
          placeholder="Search"
        />
      </div>

      <!-- cart -->
      <%= link_to "#", class: "relative flex items-center" do %>
        <svg class="w-6 h-6 text-gray-700" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="1.5" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13l-1.5 6h13"/>
        </svg>
        <span class="absolute -top-2 -right-2 text-xs bg-black text-white rounded-full px-1">
          2
        </span>
      <% end %>

      <!-- auth -->
      <%= link_to "Login", "#", class: "text-sm text-gray-600" %>
      <%= link_to "Sign up", "#", class: "text-sm font-medium" %>

      <!-- mobile menu -->
      <button data-collapse-toggle="navbar-search" type="button" class="inline-flex items-center p-2 w-10 h-10 justify-center md:hidden">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-width="2" d="M5 7h14M5 12h14M5 17h14"/>
        </svg>
      </button>

    </div>

    <!-- menu -->
    <div class="items-center justify-between hidden w-full md:flex md:w-auto md:order-1" id="navbar-search">
      <ul class="font-medium flex flex-col p-4 md:p-0 mt-4 md:flex-row md:space-x-8 md:mt-0">
        <li><a href="#" class="block py-2 px-3 text-sm">Home</a></li>
        <li><a href="#" class="block py-2 px-3 text-sm">Shop</a></li>
        <li><a href="#" class="block py-2 px-3 text-sm">Contact</a></li>
      </ul>
    </div>

  </div>
